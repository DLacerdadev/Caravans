# Copie para apps/api/.env e ajuste conforme necessário (NÃO versione segredos reais).

# Banco de dados (combina com docker-compose.yml — porta 55432 p/ evitar Postgres nativo na 5432)
DATABASE_URL="postgresql://caravans:caravans@localhost:55432/caravans?schema=public"

# Servidor da API
API_PORT=3000
# Origem permitida do front (Vite)
WEB_ORIGIN="http://localhost:5173"

# Autenticação (dev — troque em produção)
JWT_SECRET="dev-only-change-me"
COOKIE_SECURE=false

# Uploads
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=5
